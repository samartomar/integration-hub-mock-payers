# FastAPI Mock Healthcare API
# Copy to .env and adjust as needed

API_TITLE=Healthcare Mock API
API_VERSION=1.0.0
API_DESCRIPTION=Standards-aligned mock API for U.S. healthcare administrative workflows

LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Auth: When AUTH0_ISSUER is set, real JWT validation via JWKS.
# When empty, mock mode accepts any non-empty Bearer token.
# ---------------------------------------------------------------------------

# LH001 (gosam.us.auth0.com issues tokens for lh001.api.onrender.com)
AUTH0_DOMAIN=gosam.us.auth0.com
AUTH0_ISSUER=https://gosam.us.auth0.com/
AUTH0_AUDIENCE=https://lh001.api.onrender.com/
AUTH0_REQUIRED_SCOPE_EXECUTE=execute
AUTH0_REQUIRED_SCOPE_AI_EXECUTE=ai_execute
PARTNER_CODE=LH001

# Optional: restrict endpoints (comma-separated). Empty = all allowed.
# ALLOWED_OPERATIONS=get-verify-member-eligibility,get-member-accumulators

# ---------------------------------------------------------------------------
# LH030 (dev-4tuxv42k7o4csoig.us.auth0.com issues tokens for lh030.api.onrender.com)
# ---------------------------------------------------------------------------
# AUTH0_DOMAIN=dev-4tuxv42k7o4csoig.us.auth0.com
# AUTH0_ISSUER=https://dev-4tuxv42k7o4csoig.us.auth0.com/
# AUTH0_AUDIENCE=https://lh030.api.onrender.com/
# AUTH0_REQUIRED_SCOPE_EXECUTE=execute
# AUTH0_REQUIRED_SCOPE_AI_EXECUTE=ai_execute
# PARTNER_CODE=LH030

# ---------------------------------------------------------------------------
# GOSAM: use separate AUTH0_ISSUER / AUTH0_AUDIENCE per deployment.
# ---------------------------------------------------------------------------
